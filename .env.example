# PixelFPS Platform — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase (supabase.co)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_DB_PASSWORD=

# GitHub (for deploy scripts)
GITHUB_TOKEN=

# Game Engine
GAME_ENGINE_URL=https://game.pixelfps.com
